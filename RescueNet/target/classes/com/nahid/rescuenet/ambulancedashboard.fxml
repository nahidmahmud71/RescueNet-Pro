<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nahid.rescuenet.controller.AmbulanceController">
    <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <VBox prefWidth="280.0" minWidth="280.0" styleClass="sidebar-police" spacing="20" alignment="TOP_CENTER">
            <Label text="RescueNet" styleClass="police-title" style="-fx-padding: 35 0 0 0;" />
            <Label text="EMS PARAMEDIC DISPATCH" styleClass="subtitle-text" style="-fx-font-size: 13px;" />
            <VBox spacing="15" alignment="CENTER" style="-fx-padding: 40 25 0 25;">
                <Button text="Live Traffic &amp; Routes" styleClass="action-btn-cyan" onAction="#checkTraffic" maxWidth="1.7976931348623157E308" />
                <Button text="Available ER Wards" styleClass="action-btn-cyan" onAction="#viewHospitals" maxWidth="1.7976931348623157E308" />
                <Button text="Notify Blood Bank" styleClass="action-btn-cyan" onAction="#notifyBloodBank" maxWidth="1.7976931348623157E308" />
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
            <VBox alignment="CENTER" style="-fx-padding: 0 25 45 25;">
                <Button text="SECURE LOGOUT" styleClass="logout-btn" onAction="#logout" maxWidth="1.7976931348623157E308" />
            </VBox>
        </VBox>
        <VBox styleClass="root" HBox.hgrow="ALWAYS" spacing="20" style="-fx-padding: 30;">
            <Label text="Ambulance Command Center" styleClass="police-title" />
            <Label fx:id="medicNameLabel" styleClass="subtitle-text" />
            <HBox spacing="30">
                <VBox styleClass="stat-card-glass" HBox.hgrow="ALWAYS">
                    <Label text="Awaiting Pickup (Critical / SOS)" styleClass="stat-label"/>
                    <Label fx:id="activeAlertsLabel" styleClass="stat-number" style="-fx-text-fill:#ff0844;"/>
                </VBox>
                <VBox styleClass="stat-card-glass" HBox.hgrow="ALWAYS">
                    <Label text="Ambulances En Route to ER" styleClass="stat-label"/>
                    <Label fx:id="dispatchedLabel" styleClass="stat-number" style="-fx-text-fill:#00fa9a;"/>
                </VBox>
            </HBox>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button text="Dispatch Ambulance" styleClass="action-btn-cyan" onAction="#acceptEmergency" />
                <Button text="Patient Secured (To Hospital)" styleClass="action-btn-green" onAction="#markSecured" />
                <Button text="GPS Navigation" styleClass="action-btn-gold" onAction="#openLiveMap" />
            </HBox>
            <TableView fx:id="emergencyTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol" text="Dispatch ID" prefWidth="80"/>
                    <TableColumn fx:id="typeCol" text="Emergency Code" prefWidth="120"/>
                    <TableColumn fx:id="priorityCol" text="Triage Priority" prefWidth="150"/>
                    <TableColumn fx:id="locationCol" text="Pickup Location" prefWidth="300"/>
                    <TableColumn fx:id="guardianCol" text="Caller Contact" prefWidth="150"/>
                    <TableColumn fx:id="statusCol" text="Unit Status" prefWidth="120"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </HBox>
</AnchorPane>