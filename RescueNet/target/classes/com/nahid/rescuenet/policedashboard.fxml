<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<AnchorPane stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nahid.rescuenet.controller.PoliceController">
    <HBox AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <VBox prefWidth="280.0" minWidth="280.0" styleClass="sidebar-police" spacing="20" alignment="TOP_CENTER">
            <Label text="RescueNet" styleClass="police-title" style="-fx-padding: 35 0 0 0;" />
            <Label text="COMMAND DISPATCH" styleClass="subtitle-text" />
            <VBox spacing="15" alignment="CENTER" style="-fx-padding: 40 25 0 25;">
                <Button text="Deploy Drone View" styleClass="action-btn-cyan" onAction="#deployDrone" maxWidth="1.7976931348623157E308" />
                <Button text="Request Medical Backup" styleClass="action-btn-cyan" onAction="#requestMedicalBackup" maxWidth="1.7976931348623157E308" />
            </VBox>
            <Region VBox.vgrow="ALWAYS" />
            <VBox alignment="CENTER" style="-fx-padding: 0 25 45 25;">
                <Button text="SECURE LOGOUT" styleClass="logout-btn" onAction="#logout" maxWidth="1.7976931348623157E308" />
            </VBox>
        </VBox>
        <VBox styleClass="root" HBox.hgrow="ALWAYS" spacing="20" style="-fx-padding: 30;">
            <Label text="Tactical Operations Board" styleClass="police-title" />
            <Label fx:id="officerNameLabel" styleClass="subtitle-text" />
            <HBox spacing="30">
                <VBox styleClass="stat-card-glass" HBox.hgrow="ALWAYS">
                    <Label text="Active Threats" styleClass="stat-label"/>
                    <Label fx:id="activeAlertsLabel" styleClass="stat-number" style="-fx-text-fill:#ff0844;"/>
                </VBox>
                <VBox styleClass="stat-card-glass" HBox.hgrow="ALWAYS">
                    <Label text="Units Deployed" styleClass="stat-label"/>
                    <Label fx:id="dispatchedLabel" styleClass="stat-number" style="-fx-text-fill:#00e5ff;"/>
                </VBox>
            </HBox>
            <HBox spacing="15" alignment="CENTER_LEFT">
                <Button text="Engage Target &amp; Notify" styleClass="action-btn-cyan" onAction="#acceptEmergency" />
                <Button text="Threat Neutralized" styleClass="action-btn-green" onAction="#markResolved" />
                <Button text="Track on Live Map" styleClass="action-btn-gold" onAction="#openLiveMap" />
            </HBox>
            <TableView fx:id="emergencyTable" VBox.vgrow="ALWAYS">
                <columns>
                    <TableColumn fx:id="idCol" text="Case ID" prefWidth="80"/>
                    <TableColumn fx:id="typeCol" text="Threat Type" prefWidth="120"/>
                    <TableColumn fx:id="locationCol" text="Incident Location" prefWidth="300"/>
                    <TableColumn fx:id="emailCol" text="Victim Email" prefWidth="200"/>
                    <TableColumn fx:id="guardianCol" text="Emergency Contact" prefWidth="150"/>
                    <TableColumn fx:id="statusCol" text="Status" prefWidth="100"/>
                </columns>
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                </columnResizePolicy>
            </TableView>
        </VBox>
    </HBox>
</AnchorPane>