<?xml version="1.0" encoding="UTF-8"?>
<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane prefHeight="700.0" prefWidth="900.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nahid.rescuenet.controller.RegisterController">
    <VBox alignment="CENTER" maxWidth="450.0" maxHeight="650.0" spacing="20.0" styleClass="login-card" StackPane.alignment="CENTER">
        <VBox alignment="CENTER" spacing="5.0">
            <HBox alignment="CENTER" spacing="10.0">
                <Circle fill="#00e5ff" radius="5.0" />
                <Label styleClass="title-text" text="Registration" />
            </HBox>
            <Label styleClass="subtitle-text" text="Join the emergency response network" />
        </VBox>
        <VBox spacing="12.0">
            <VBox spacing="5.0">
                <Label styleClass="field-label" text="UNIT / FULL NAME" />
                <TextField fx:id="nameField" promptText="Enter official name" styleClass="text-field" />
            </VBox>
            <VBox spacing="5.0">
                <Label styleClass="field-label" text="CONTACT NUMBER" />
                <TextField fx:id="phoneField" promptText="Active phone number" styleClass="text-field" />
            </VBox>
            <VBox spacing="5.0">
                <Label styleClass="field-label" text="EMAIL ADDRESS" />
                <TextField fx:id="emailField" promptText="Personal or official email" styleClass="text-field" />
            </VBox>
            <VBox spacing="5.0">
                <Label styleClass="field-label" text="GUARDIAN PHONE (For Citizens)" />
                <TextField fx:id="guardianPhoneField" promptText="Emergency contact number" styleClass="text-field" />
            </VBox>
            <VBox spacing="5.0">
                <Label styleClass="field-label" text="SECURE PASSWORD" />
                <PasswordField fx:id="passwordField" promptText="Create strong password" styleClass="password-field" />
            </VBox>
            <VBox spacing="5.0">
                <Label styleClass="field-label" text="ASSIGNMENT ROLE" />
                <ComboBox fx:id="roleComboBox" maxWidth="1.7976931348623157E308" promptText="Select Unit Type" styleClass="combo-box">
                    <items>
                        <FXCollections fx:factory="observableArrayList">
                            <String fx:value="Citizen" />
                            <String fx:value="Police" />
                            <String fx:value="Ambulance" />
                            <String fx:value="Hospital" />
                            <String fx:value="Fire Service" />
                            <String fx:value="Admin" />
                        </FXCollections>
                    </items>
                </ComboBox>
            </VBox>
        </VBox>
        <VBox alignment="CENTER" spacing="15.0">
            <Button maxWidth="1.7976931348623157E308" onAction="#registerButtonClicked" styleClass="primary-btn" text="REGISTER SECURE NODE" />
            <Region styleClass="divider" />
            <Button onAction="#goToLogin" styleClass="secondary-btn" text="Already have an account? Sign In" />
        </VBox>
    </VBox>
</StackPane>