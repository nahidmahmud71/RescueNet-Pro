<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.shape.Circle?>
<?import javafx.scene.shape.Line?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="450.0" prefWidth="650.0"
            style="-fx-background-color: #060913; -fx-border-color: #00fa9a; -fx-border-width: 2;"
            xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.nahid.rescuenet.controller.MapTrackingController">
    <children>
        <Label layoutX="20.0" layoutY="15.0" text="GLOBAL POSITIONING SYSTEM (GPS) - LIVE" textFill="#00fa9a">
            <font>
                <Font name="System Bold" size="18.0"/>
            </font>
        </Label>
        <Label fx:id="targetLocLabel" layoutX="20.0" layoutY="45.0" text="Target: " textFill="#00e5ff"/>

        <AnchorPane layoutX="25.0" layoutY="80.0" prefHeight="300.0" prefWidth="600.0"
                    style="-fx-border-color: #1e293b; -fx-background-color: #0a1128;">
            <children>
                <Line endX="600.0" layoutY="150.0" stroke="#1e293b"/>
                <Line endY="300.0" layoutX="300.0" stroke="#1e293b"/>

                <Circle fx:id="pingDot" fill="#ff0844" layoutX="300.0" layoutY="150.0" radius="6.0"/>
                <Circle fx:id="radarRing" fill="TRANSPARENT" layoutX="300.0" layoutY="150.0" radius="6.0"
                        stroke="#ff0844" strokeWidth="2.0"/>
                <Label layoutX="315.0" layoutY="135.0" text="INCIDENT ORIGIN" textFill="#ff0844">
                    <font>
                        <Font name="System Bold" size="10.0"/>
                    </font>
                </Label>
            </children>
        </AnchorPane>
        <Label layoutX="25.0" layoutY="395.0" text="Uplink Status: SECURE | Encryption: AES-256 | Frequency: 144.5 MHz"
               textFill="#8892b0"/>
        <Button layoutX="520.0" layoutY="390.0" mnemonicParsing="false" onAction="#openRealGoogleMaps"
                style="-fx-background-color: #00e5ff; -fx-text-fill: #000000; -fx-font-weight: bold; -fx-cursor: hand;"
                text="Google Map"/>
    </children>
</AnchorPane>