<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Circle?>

<StackPane prefHeight="700.0" prefWidth="900.0" stylesheets="@style.css" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.nahid.rescuenet.controller.LoginController">
    <VBox alignment="CENTER" maxWidth="400.0" maxHeight="500.0" spacing="30.0" styleClass="login-card" StackPane.alignment="CENTER">
        <VBox alignment="CENTER" spacing="5.0">
            <HBox alignment="CENTER" spacing="10.0">
                <Circle fill="#00e5ff" radius="6.0" />
                <Label styleClass="title-text" text="RescueNet Login" />
            </HBox>
            <Label styleClass="subtitle-text" text="Sign in to your account" />
        </VBox>
        <VBox spacing="15.0">
            <VBox spacing="5.0">
                <Label styleClass="field-label" text="PHONE NUMBER" />
                <TextField fx:id="phoneField" promptText="Enter your phone number" styleClass="text-field" />
            </VBox>
            <VBox spacing="5.0">
                <Label styleClass="field-label" text="PASSWORD" />
                <PasswordField fx:id="passwordField" promptText="Enter your password" styleClass="password-field" />
            </VBox>
        </VBox>
        <VBox alignment="CENTER" spacing="15.0">
            <Button maxWidth="1.7976931348623157E308" onAction="#loginButtonClicked" styleClass="primary-btn" text="LOGIN" />
            <Region styleClass="divider" />
            <Button onAction="#goToRegister" styleClass="secondary-btn" text="Don't have an account? Register" />
        </VBox>
    </VBox>
</StackPane>